# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="https://tendergo-taiwan.pages.dev/"

# VITE_API_BASE_URL: Frontend API base URL.
# Local example: leave empty to use same-origin (recommended when front+worker are routed together).
# If frontend and worker are on different domains, set full URL (e.g. https://tendergo-worker.<your-subdomain>.workers.dev)
VITE_API_BASE_URL="https://tendergo-worker.husk9612.workers.dev"

# VITE_ENABLE_MOCK_FALLBACK: true 時 API 失敗會使用前端 mock 資料。
# 正式環境建議設為 false，避免誤以為已接上後端。
VITE_ENABLE_MOCK_FALLBACK="false"
